# Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: Sentry error monitoring. Leave unset to disable (no-ops safely).
# Get this from your Sentry project settings -> Client Keys (DSN).
NEXT_PUBLIC_SENTRY_DSN=

# Optional: trip soundtracks (Spotify track search). Leave unset and the
# soundtrack picker just shows "Spotify isn't set up yet." — nothing else
# breaks. Create a free app at https://developer.spotify.com/dashboard,
# then copy its Client ID and Client Secret here. Server-side only —
# never exposed to the browser.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
